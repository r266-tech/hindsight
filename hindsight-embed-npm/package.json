{
  "name": "@vectorize-io/hindsight-embed",
  "version": "0.5.0",
  "description": "Node.js wrapper for the hindsight-embed Python CLI — spawns and talks to a local hindsight-embed daemon, or proxies to a remote Hindsight API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "keywords": [
    "hindsight",
    "hindsight-embed",
    "memory",
    "ai",
    "agent",
    "long-term-memory",
    "llm"
  ],
  "author": "Vectorize <support@vectorize.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vectorize-io/hindsight.git",
    "directory": "hindsight-embed-npm"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest run src",
    "test:watch": "vitest src",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "rollup": "^4.59.0",
    "picomatch": ">=2.3.2 <3.0.0 || >=4.0.4",
    "vite": ">=8.0.5"
  }
}
